<!DOCTYPE html>
<html>
<head>
    <title>Recipe Book </title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #fde4ec;
            margin: 0;
            padding: 0;
        }

        header {
            background: #f06292;
            color: white;
            padding: 25px;
            text-align: center;
        }

        header h1 {
            font-weight: 600;
            margin-bottom: 5px;
        }

        header p {
            font-weight: 300;
        }

        .container {
            width: 80%;
            margin: auto;
            margin-top: 30px;
        }

        .form-card, .recipe-card {
            background: #ffffff;
            padding: 22px;
            border-radius: 14px;
            margin-bottom: 20px;
            box-shadow: 0 4px 12px rgba(240, 98, 146, 0.3);
        }

        h2, h3 {
            color: #e91e63;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            border-radius: 6px;
            border: 1px solid #f8bbd0;
            font-family: 'Poppins', sans-serif;
        }

        input:focus {
            outline: none;
            border-color: #e91e63;
        }

        button {
            background: #ec407a;
            color: white;
            border: none;
            padding: 10px 18px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            font-family: 'Poppins', sans-serif;
        }

        button:hover {
            background: #d81b60;
        }

        .recipes {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
        }

        .recipe-card p {
            color: #555;
            font-weight: 300;
        }

        .actions {
            margin-top: 10px;
        }

        a {
            text-decoration: none;
            color: #e91e63;
            font-weight: 500;
            margin-right: 10px;
        }

        a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

<header>
    <h1>🍽️ Recipe Book</h1>
    <p>✨ Manage your favorite recipes with love </p>
</header>

<div class="container">

    <div class="form-card">
        <h2>➕ Add New Recipe </h2>
        <form action="/add" method="POST">
            <input type="text" name="name" placeholder=" Recipe Name" required>
            <input type="text" name="description" placeholder=" Recipe Description" required>
            <button type="submit"> Add Recipe</button>
        </form>
    </div>

    <h2> All Recipes</h2>

    <div class="recipes">
        <% recipes.forEach(recipe => { %>
            <div class="recipe-card">
                <h3> <%= recipe.name %></h3>
                <p> <%= recipe.description.substring(0, 60) %>...</p>

                <div class="actions">
                    <a href="/recipe/<%= recipe.id %>"> View Details</a>
                    <form action="/delete/<%= recipe.id %>?_method=DELETE"
                          method="POST"
                          style="display:inline;">
                        <button type="submit"> Delete</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>

</div>

</body>
</html>

